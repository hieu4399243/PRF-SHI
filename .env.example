# Sao chép file này thành .env rồi điền giá trị thật. KHÔNG commit file .env.

# Kết nối Postgres của Supabase (Project → Settings → Database → Connection string).
# Khuyên dùng "Connection pooler" / chế độ Transaction (cổng 6543).
# Bỏ trống / xóa dòng này -> app tự dùng file JSON (local), không cần DB.
DATABASE_URL=postgresql://postgres.xxxx:YOUR-PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# Khóa bí mật cho Flask session (production nên đặt chuỗi ngẫu nhiên).
SECRET_KEY=doi-thanh-mot-chuoi-ngau-nhien
