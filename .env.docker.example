# Sao chép file này thành .env (cùng cấp docker-compose.yml) rồi điền giá trị thật.
# KHÔNG commit file .env. Dùng riêng cho `docker compose up` — khác với .env.example
# (file đó dành cho chạy backend KHÔNG qua Docker, không có POSTGRES_PASSWORD).

# Postgres local chạy trong service "db" của docker-compose.yml.
POSTGRES_DB=shi
POSTGRES_USER=shi
POSTGRES_PASSWORD=doi-thanh-mat-khau-ngau-nhien

# Khóa bí mật cho Flask session (production nên đặt chuỗi ngẫu nhiên).
SECRET_KEY=doi-thanh-mot-chuoi-ngau-nhien

# Khóa truy cập /api/admin/* (header X-Admin-Key). Production PHẢI đổi khỏi giá trị demo.
ADMIN_KEY=doi-thanh-khoa-admin-rieng
